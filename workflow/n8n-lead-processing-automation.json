    {
      "parameters": {
        "jsCode": "const items = $input.all();\nlet listText = \"🚀 *New Batch of Leads for Review*:\\n\\n\";\n\nitems.forEach((item, index) => {\n  // Access the 'fields' object where your Airtable/CRM data lives\n  const d = item.json.fields; \n  \n  if (d) {\n    // Note: Use the exact capitalization from your input (e.g., \"Company Name\")\n    const name = d[\"Company Name\"] || \"Unknown\";\n    const size = d[\"Company Size\"] || \"N/A\";\n    const country = d[\"Country\"] || \"N/A\";\n\n    listText += `${index + 1}. *${name}* - ${size} pax (${country})\\n`;\n  }\n});\n\nreturn {\n  summary: listText,\n  count: items.length\n};"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,

      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const input = $input.item.json;\n\n// Define your required fields and how you want them to appear in the message\nconst requiredFields = {\n  \"company_name\": \"Company Name\",\n  \"email_address\": \"Email Address\",\n  \"contact_number\": \"Contact Number\",\n  \"inquiry_message\": \"Inquiry Message\"\n};\n\nlet missingList = [];\n\n// Loop through and check for null or empty strings\nfor (const key in requiredFields) {\n  if (input[key] === null || input[key] === undefined || input[key].toString().trim() === \"\") {\n    missingList.push(requiredFields[key]);\n  }\n}\n\nreturn {\n  company_name: input.company_name || \"Valued Customer\",\n  missing_string: missingList.join(\", \"),\n  has_missing: missingList.length > 0\n};"
      },
